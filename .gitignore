*.iml
.gradle
/local.properties
/.idea
/build
/app/build
/captures
.externalNativeBuild
.cxx
local.properties

# YouCoded local Claude Code settings (caches, topic markers, etc.).
# Tracked rule files under .claude/rules/ are explicitly un-ignored so
# they ship with the repo and auto-surface invariants to contributors.
# Note: .claude/* (not .claude/) is required so git descends into the
# directory and honors the negation patterns below.
.claude/*
!.claude/rules/
!.claude/rules/**

# Release signing
*.jks
*.keystore
keystore.properties
# Exception: debug keystore is publicly known (password "android") and is
# intentionally committed so every dev build shares one signing key.
!app/debug.keystore

# Drafts and temp files
icon-drafts/
tmp-screenshots/
screenshot.png

# Git worktrees (isolated feature workspaces)
.worktrees/

# Desktop app (Electron)
node_modules/
desktop/dist/
desktop/build/
desktop/release/
# Electron runtime debug logs — machine-specific, leak local paths
*.log

# Built React UI bundle (copied from desktop build) — except placeholder
app/src/main/assets/web/*
!app/src/main/assets/web/index.html
.worktrees/
